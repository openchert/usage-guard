{
  "name": "usage-guard",
  "version": "0.3.0",
  "private": false,
  "description": "Local-first AI usage monitor with cross-platform desktop app and CLI",
  "author": {
    "name": "Lukas",
    "email": "lukas@usage-guard.local"
  },
  "license": "MIT",
  "type": "module",
  "main": "apps/desktop/src/main.js",
  "bin": {
    "usageguard": "apps/cli/bin/usageguard.js"
  },
  "scripts": {
    "start": "electron apps/desktop/src/main.js",
    "cli:demo": "node apps/cli/bin/usageguard.js demo",
    "cli:check": "node apps/cli/bin/usageguard.js check --spent 12 --limit 20 --inactive-hours 9",
    "test": "node --test tests/*.test.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "electron-store": "^10.1.0"
  },
  "devDependencies": {
    "electron": "^35.1.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "ai.usageguard.app",
    "productName": "UsageGuard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "apps/**/*",
      "core/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "category": "Utility",
      "maintainer": "Lukas <lukas@usage-guard.local>",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
