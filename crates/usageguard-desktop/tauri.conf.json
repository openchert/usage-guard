{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UsageGuard",
  "version": "0.4.0",
  "identifier": "com.usageguard.app",
  "build": {
    "beforeBuildCommand": "npm run build --prefix ui",
    "frontendDist": "ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "UsageGuard",
        "width": 244,
        "height": 100,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png"
    ]
  }
}
